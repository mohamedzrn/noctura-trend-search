# Instagram credentials for the bot account
INSTAGRAM_USERNAME=your_bot_account
INSTAGRAM_PASSWORD=your_bot_password

# Path to save the Instagram session (avoids re-login on restart)
SESSION_FILE=session.json

# How often to poll for new DMs (seconds)
POLL_INTERVAL_SECONDS=60

# Residential proxy (DataImpulse or similar)
PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=823
PROXY_USERNAME=
PROXY_PASSWORD=

# Anthropic API key for Claude analysis
ANTHROPIC_API_KEY=sk-ant-...

# SQLite database file
DB_PATH=trends.db

# Comma-separated list of approved team Instagram usernames (blank = accept from anyone)
ALLOWED_SENDER=
ALLOWED_SENDERS=username1,username2,username3

# Notion integration
# Get your token from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...
# Fallback database ID (used if submitter is not in NOTION_CREATOR_DBS)
NOTION_DATABASE_ID=
# Per-creator routing: maps Instagram username → Notion database ID
# Open each creator's reels page in Notion, copy the ID from the URL
# Format: {"instagram_username": "notion_database_id", ...}
NOTION_CREATOR_DBS={"aryminh": "", "lycheebobaxo": ""}
